# file: examples/cockroach-rollout-agent.env.example
# version: 1.0.0
# guid: 3d948f0d-6c0b-46b0-b9cc-fc7f6cf77a9f

# Host-local configuration for cockroach-rollout-agent.
# Copy to /etc/cockroach-rollout-agent.env and set permissions to 0600.
# Do not commit real values.

CROACH_ROLLOUT_DATABASE_URL=postgresql://rollout@localhost:26257/defaultdb?sslmode=require
CROACH_ROLLOUT_ARTIFACTS_DIR=/var/lib/cockroach-rollout-agent/artifacts
CROACH_ROLLOUT_AUDIT_LOG=/var/log/cockroach-rollout-agent/audit.log
CROACH_ROLLOUT_BINARY_PATH=/usr/local/bin/cockroach
CROACH_ROLLOUT_SERVICE=cockroachdb.service
CROACH_ROLLOUT_SCHEMA=cockroach_rollout

# Optional stable ID if hostname is not unique or agents run in containers.
# CROACH_ROLLOUT_NODE_ID=node-1
